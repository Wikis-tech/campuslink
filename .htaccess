Options -Indexes
Options -MultiViews

# Security: Deny access to sensitive files
<FilesMatch "\.(env|sql|log|md|txt|gitignore|gitattributes)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(\.htaccess|\.htpasswd)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to config and core directories
RedirectMatch 404 ^/campuslink/(config|core|database|logs|scripts)/.*$

# Turn on URL rewriting
RewriteEngine On

# Set the base — IMPORTANT for InfinityFree
# If your site is at the root of the domain use /
# If it is in a subfolder e.g. /campuslink/ use /campuslink/
RewriteBase /campuslink/

# Step 1: If the request is for a real existing FILE, serve it directly
# (this allows CSS, JS, images, uploads to load normally)
RewriteCond %{REQUEST_FILENAME} !-f

# Step 2: If the request is for a real existing DIRECTORY, serve it directly
RewriteCond %{REQUEST_FILENAME} !-d

# Step 3: Everything else goes to index.php
# QSA = keep query string (?type=student etc)
# L   = last rule, stop processing
RewriteRule ^(.*)$ index.php [QSA,L]